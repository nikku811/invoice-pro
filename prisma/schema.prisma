generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String           @id @default(cuid())
  name      String
  email     String           @unique
  password  String
  createdAt DateTime         @default(now())
  profile   BusinessProfile?
  invoices  Invoice[]

  @@map("users")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  date          DateTime
  clientName    String
  address       String?
  subject       String?
  subtotal      Float         @default(0)
  total         Float         @default(0)
  totalInWords  String?
  notes         String?
  userId        String
  createdAt     DateTime      @default(now())
  status        InvoiceStatus @default(DRAFT)
  items         InvoiceItem[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([invoiceNumber])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  rate        Float
  amount      Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model BusinessProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  orgName    String
  orgAddress String?
  orgPhone   String?
  orgEmail   String?
  orgWebsite String?
  orgGstin   String?
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_profiles")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}
